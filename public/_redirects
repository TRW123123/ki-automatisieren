# Netlify Redirects
# Force HTTPS
http://ki-automatisieren.de/* https://ki-automatisieren.de/:splat 301!

# Canonical Domain (non-www)
https://www.ki-automatisieren.de/* https://ki-automatisieren.de/:splat 301!

# Legacy URL Redirects (P0) - Explicit 301s
# Netlify CDN normalizes trailing slashes before matching, so both /ueber-mich and /ueber-mich/ match
/ueber-mich/                    /uber-uns/                                   301
/automatisierung-mit-ki/        /losungen/                                   301
/ki-sales-automatisierung/      /losungen/vertriebsautomatisierung/          301
/ki-training/                   /losungen/strategieberatung-ki-sales-marketing/ 301
/social-media/                  /losungen/marketing-automatisierung/         301

# Sitemap alias (Astro generates sitemap-index.xml)
/sitemap.xml                    /sitemap-index.xml                           301

# Zombie-URLs aus altem CMS (Ghost/Wix) — GSC indexiert diese noch
/post/revolution-im-kundenservice-ki-chatbots-als-automatisierungsl%C3%B6sung /blog/kundenservice-chatbot-ki-mittelstand-automatisierung/ 301
/post/*                         /blog/                                       301

# Alte Kategorie-Seiten → Blog-Index
/blog/categories/*  /blog/  301
/blog/category/*    /blog/  301
/blog/tag/*         /blog/  301
/blog/tags/*        /blog/  301

# /de/ Zombie-Pfade (falls historisch indiziert)
/de/*   /  301

# Prevent Pretty URLs from adding slash to file assets
/site.webmanifest/              /site.webmanifest                            301!

# Clean URLs (Standard Netlify)
/index.html                     /                                            301
