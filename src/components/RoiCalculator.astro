---
// ROI-Rechner — statische Astro-Komponente, kein React
// Eingabe: Mitarbeiter, Stunden/Woche für manuelle Prozesse, Stundensatz
// Ausgabe: gesparte Stunden/Jahr, gesparte Kosten €, Break-even

interface Props {
  defaultEmployees?: number;
  defaultHours?: number;
  defaultRate?: number;
  defaultAuto?: number;
  headline?: string;
}

const {
  defaultEmployees = 3,
  defaultHours = 8,
  defaultRate = 35,
  defaultAuto = 70,
  headline = "Was kostet Sie manuelle Arbeit wirklich?",
} = Astro.props;
---

<section class="py-20 bg-card/30 border-y border-white/5 relative overflow-hidden" aria-label="ROI-Rechner">
  <!-- Subtle background glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-lime-400/5 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

  <div class="container mx-auto px-4 sm:px-6 relative z-10">

    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-sm font-semibold text-lime-400 uppercase tracking-widest mb-3">Kostenloser Rechner</p>
      <h2 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
        {headline}
      </h2>
      <p class="text-gray-400 max-w-xl mx-auto">
        Berechnen Sie Ihr persönliches Einsparpotenzial durch KI-Automatisierung — in unter 30 Sekunden.
      </p>
    </div>

    <!-- Calculator Card -->
    <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-0 rounded-2xl overflow-hidden border border-white/10 shadow-2xl">

      <!-- Left: Inputs -->
      <div class="bg-card/80 backdrop-blur-sm p-8 space-y-7">
        <h3 class="text-lg font-semibold text-foreground mb-2">Ihr Unternehmen</h3>

        <!-- Mitarbeiter -->
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <label for="roi-employees" class="text-sm font-medium text-gray-300">
              Mitarbeiter mit manuellen Prozessen
            </label>
            <span id="roi-employees-val" class="text-lime-400 font-bold text-sm min-w-[2rem] text-right">{defaultEmployees}</span>
          </div>
          <input
            type="range"
            id="roi-employees"
            min="1" max="50" value={defaultEmployees} step="1"
            class="roi-slider w-full h-2 rounded-lg appearance-none cursor-pointer"
          />
          <div class="flex justify-between text-xs text-gray-600">
            <span>1</span><span>25</span><span>50</span>
          </div>
        </div>

        <!-- Stunden pro Woche -->
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <label for="roi-hours" class="text-sm font-medium text-gray-300">
              Stunden/Woche pro Person für manuelle Aufgaben
            </label>
            <span id="roi-hours-val" class="text-lime-400 font-bold text-sm min-w-[2rem] text-right">{defaultHours}</span>
          </div>
          <input
            type="range"
            id="roi-hours"
            min="1" max="40" value={defaultHours} step="1"
            class="roi-slider w-full h-2 rounded-lg appearance-none cursor-pointer"
          />
          <div class="flex justify-between text-xs text-gray-600">
            <span>1h</span><span>20h</span><span>40h</span>
          </div>
        </div>

        <!-- Stundensatz -->
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <label for="roi-rate" class="text-sm font-medium text-gray-300">
              Durchschnittlicher Brutto-Stundensatz (€)
            </label>
            <span id="roi-rate-val" class="text-lime-400 font-bold text-sm min-w-[3rem] text-right">{defaultRate} €</span>
          </div>
          <input
            type="range"
            id="roi-rate"
            min="15" max="120" value={defaultRate} step="5"
            class="roi-slider w-full h-2 rounded-lg appearance-none cursor-pointer"
          />
          <div class="flex justify-between text-xs text-gray-600">
            <span>15 €</span><span>65 €</span><span>120 €</span>
          </div>
        </div>

        <!-- Automatisierungsgrad -->
        <div class="space-y-3">
          <div class="flex justify-between items-center">
            <label for="roi-auto" class="text-sm font-medium text-gray-300">
              Automatisierungsgrad (realistisch)
            </label>
            <span id="roi-auto-val" class="text-lime-400 font-bold text-sm min-w-[2rem] text-right">{defaultAuto}%</span>
          </div>
          <input
            type="range"
            id="roi-auto"
            min="30" max="90" value={defaultAuto} step="5"
            class="roi-slider w-full h-2 rounded-lg appearance-none cursor-pointer"
          />
          <div class="flex justify-between text-xs text-gray-600">
            <span>30%</span><span>60%</span><span>90%</span>
          </div>
        </div>
      </div>

      <!-- Right: Results -->
      <div class="bg-gradient-to-br from-lime-950/60 to-card/90 p-8 flex flex-col justify-between border-l border-white/5">
        <div>
          <h3 class="text-lg font-semibold text-foreground mb-6">Ihr Einsparpotenzial</h3>

          <!-- Main metric -->
          <div class="mb-8 text-center py-6 bg-black/20 rounded-xl border border-lime-400/20">
            <p class="text-xs text-gray-500 uppercase tracking-wider mb-1">Ersparnis pro Jahr</p>
            <p id="roi-savings" class="text-5xl font-black text-lime-400 leading-none">0 €</p>
            <p class="text-xs text-gray-500 mt-2">in Personalkosten</p>
          </div>

          <!-- Secondary metrics -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="bg-black/20 rounded-xl p-4 text-center border border-white/5">
              <p class="text-xs text-gray-500 mb-1">Gesparte Stunden</p>
              <p id="roi-hours-saved" class="text-2xl font-bold text-foreground">0</p>
              <p class="text-xs text-gray-600">pro Jahr</p>
            </div>
            <div class="bg-black/20 rounded-xl p-4 text-center border border-white/5">
              <p class="text-xs text-gray-500 mb-1">Break-even</p>
              <p id="roi-breakeven" class="text-2xl font-bold text-foreground">—</p>
              <p class="text-xs text-gray-600">Monate</p>
            </div>
          </div>

          <!-- ROI ratio -->
          <div class="bg-black/20 rounded-xl p-4 border border-white/5">
            <div class="flex justify-between items-center mb-2">
              <span class="text-xs text-gray-500">ROI-Faktor</span>
              <span id="roi-factor" class="text-sm font-bold text-lime-400">—</span>
            </div>
            <div class="w-full bg-white/5 rounded-full h-1.5">
              <div id="roi-bar" class="bg-lime-400 h-1.5 rounded-full transition-all duration-500" style="width: 0%"></div>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-8">
          <button
            onclick="window.openQuickAnalysis()"
            class="w-full bg-primary text-primary-foreground hover:bg-primary/90 px-6 py-4 text-base font-semibold rounded-xl transition-colors duration-200"
          >
            Kostenlose Potenzialanalyse anfragen
          </button>
          <p class="text-xs text-gray-600 text-center mt-3">
            Unverbindlich · Antwort innerhalb von 24h
          </p>
        </div>
      </div>

    </div>

    <!-- Disclaimer -->
    <p class="text-center text-xs text-gray-700 mt-6">
      * Berechnung basiert auf durchschnittlichen Projektergebnissen. Individuelle Ergebnisse können abweichen.
    </p>
  </div>
</section>

<style>
  .roi-slider {
    background: linear-gradient(to right, #a3e635 0%, #a3e635 var(--progress, 0%), rgba(255,255,255,0.1) var(--progress, 0%), rgba(255,255,255,0.1) 100%);
  }
  .roi-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #a3e635;
    cursor: pointer;
    border: 2px solid #0a0f14;
    box-shadow: 0 0 8px rgba(163, 230, 53, 0.5);
  }
  .roi-slider::-moz-range-thumb {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #a3e635;
    cursor: pointer;
    border: 2px solid #0a0f14;
  }
</style>

<script>
  (function () {
    // Implementierungskosten als Basis für Break-even (realistischer Mittelwert)
    const IMPL_COST = 8000;

    function fmt(n: number) {
      return new Intl.NumberFormat('de-DE', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(n);
    }

    function updateSliderStyle(input: HTMLInputElement) {
      const min = Number(input.min);
      const max = Number(input.max);
      const val = Number(input.value);
      const pct = ((val - min) / (max - min)) * 100;
      input.style.setProperty('--progress', pct + '%');
    }

    function calc() {
      const employees = Number((document.getElementById('roi-employees') as HTMLInputElement).value);
      const hours     = Number((document.getElementById('roi-hours') as HTMLInputElement).value);
      const rate      = Number((document.getElementById('roi-rate') as HTMLInputElement).value);
      const autoRate  = Number((document.getElementById('roi-auto') as HTMLInputElement).value) / 100;

      // Labels
      (document.getElementById('roi-employees-val') as HTMLElement).textContent = String(employees);
      (document.getElementById('roi-hours-val') as HTMLElement).textContent = String(hours);
      (document.getElementById('roi-rate-val') as HTMLElement).textContent = rate + ' €';
      (document.getElementById('roi-auto-val') as HTMLElement).textContent = Math.round(autoRate * 100) + '%';

      // Berechnung
      const hoursPerYear = employees * hours * 52;
      const savedHours   = Math.round(hoursPerYear * autoRate);
      const savedCost    = savedHours * rate;
      const breakeven    = savedCost > 0 ? Math.ceil((IMPL_COST / savedCost) * 12) : null;
      const roiFactor    = savedCost > 0 ? (savedCost / IMPL_COST).toFixed(1) : null;
      const barWidth     = Math.min(100, savedCost > 0 ? (savedCost / IMPL_COST) * 20 : 0);

      // Output
      (document.getElementById('roi-savings') as HTMLElement).textContent = fmt(savedCost);
      (document.getElementById('roi-hours-saved') as HTMLElement).textContent = savedHours.toLocaleString('de-DE');
      (document.getElementById('roi-breakeven') as HTMLElement).textContent = breakeven ? breakeven + ' Mon.' : '—';
      (document.getElementById('roi-factor') as HTMLElement).textContent = roiFactor ? roiFactor + 'x Return' : '—';
      (document.getElementById('roi-bar') as HTMLElement).style.width = barWidth + '%';
    }

    const sliders = document.querySelectorAll<HTMLInputElement>('.roi-slider');
    sliders.forEach(slider => {
      updateSliderStyle(slider);
      slider.addEventListener('input', () => {
        updateSliderStyle(slider);
        calc();
      });
    });

    calc();
  })();
</script>
