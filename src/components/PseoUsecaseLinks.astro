---
import { pseoPages } from "@/data/pseoCluster";

interface Props {
  brancheSlug: string;
  brancheLabel: string;
}

const { brancheSlug, brancheLabel } = Astro.props;
const matches = pseoPages.filter(p => p.branche === brancheSlug);
---

{matches.length > 0 && (
  <section class="py-16 border-t border-white/5 bg-[#050505]" aria-label={`KI Use-Cases für ${brancheLabel}`}>
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-lime-500/30 bg-lime-500/10 text-lime-400 text-sm font-medium mb-4">
          <span class="w-2 h-2 rounded-full bg-lime-400 animate-pulse"></span>
          KI-AUTOMATISIERUNG
        </div>
        <h2 class="text-3xl font-bold text-white">Passende KI Use-Cases für {brancheLabel}</h2>
        <p class="text-gray-400 mt-3 max-w-2xl mx-auto">Spezifische Automatisierungslösungen — entwickelt für die Anforderungen in {brancheLabel}.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {matches.map(p => (
          <a
            href={`/${p.usecase}/${p.branche}/`}
            class="block p-6 rounded-2xl bg-[#0A0A0A] border border-white/10 hover:border-lime-500/40 hover:-translate-y-1 transition-all group"
          >
            <span class="text-xs font-semibold text-lime-400 uppercase tracking-wider mb-2 block">{p.usecaseLabel}</span>
            <h3 class="text-lg font-bold text-white group-hover:text-lime-400 transition-colors mb-2">{p.h1}</h3>
            <span class="text-sm text-gray-500 inline-flex items-center gap-1">
              Mehr erfahren
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
