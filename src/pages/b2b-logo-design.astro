---
import BaseLayout from "@/layouts/BaseLayout.astro";
import LogoLeadForm from "@/components/react/LogoLeadForm.tsx";

const seoTitle = "B2B Design System | High-End Logos für visuelle Autorität";
const seoDescription = "Wir trimmen Ihr Design auf Conversion. Laden Sie Ihr aktuelles Logo hoch und unser System generiert die Architektur für maximale visuelle Autorität.";
---

<BaseLayout title={seoTitle} description={seoDescription}>
    <!-- GSAP & SplitType -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script is:inline src="https://unpkg.com/split-type"></script>
    
    <!-- Phosphor Icons -->
    <script is:inline src="https://unpkg.com/@phosphor-icons/web"></script>

    <style is:inline>
        /* Specific Styles for this Landingpage to achieve the B2B Dark/Lime Aesthetic */
        :root {
            --bg-base: hsl(203, 23%, 8%);
            --surface: hsl(220, 13%, 9%);
            --text-main: hsl(210, 10%, 90%);
            --text-muted: hsl(215, 16%, 58%);
            --accent: #3b82f6; /* Blue matching the React form, instead of Lime */
            --border-color: rgba(255, 255, 255, 0.08);
            --font-display: 'Space Grotesk', system-ui, sans-serif;
            --font-ui: 'Space Grotesk', system-ui, sans-serif;
        }

        .landing-wrapper {
            background-color: var(--bg-base);
            color: var(--text-main);
            font-family: var(--font-ui);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            position: relative;
        }

        .landing-wrapper h1, .landing-wrapper h2, .landing-wrapper h3, .landing-wrapper .display-font {
            font-family: var(--font-display);
            font-weight: 700;
        }

        /* Custom Cursor */
        .c-dot, .c-ring {
            position: fixed;
            top: 0;
            left: 0;
            pointer-events: none;
            z-index: 9999;
            border-radius: 50%;
            transform: translate(-50%, -50%);
        }

        .c-dot {
            width: 8px;
            height: 8px;
            background-color: var(--accent);
            transition: opacity 0.3s ease;
            box-shadow: 0 0 10px rgba(59, 130, 246, 0.5);
        }

        .c-ring {
            width: 40px;
            height: 40px;
            border: 1px solid var(--text-muted);
            transition: width 0.3s ease, height 0.3s ease, background-color 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--font-ui);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.1em;
            color: var(--bg-base);
            overflow: hidden;
        }

        .c-text {
            opacity: 0;
            transform: scale(0.5);
            transition: opacity 0.3s ease, transform 0.3s ease;
        }

        /* Cursor States */
        body.c-interactive .c-ring {
            width: 60px;
            height: 60px;
            border-color: var(--accent);
            backdrop-filter: blur(4px);
            background-color: rgba(59, 130, 246, 0.1);
        }

        body.c-view .c-ring {
            width: 80px;
            height: 80px;
            background-color: var(--accent);
            border-color: transparent;
            box-shadow: 0 0 20px rgba(59, 130, 246, 0.4);
        }
        
        body.c-view .c-dot {
            opacity: 0;
        }

        body.c-view .c-text {
            opacity: 1;
            transform: scale(1);
        }

        /* Global Effects */
        .n-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 10;
            opacity: 0.15;
            mix-blend-mode: overlay;
        }

        .cyber-grid {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 40px 40px;
            mask-image: radial-gradient(ellipse at center, black 10%, transparent 70%);
            -webkit-mask-image: radial-gradient(ellipse at center, black 10%, transparent 70%);
            pointer-events: none;
            z-index: 1;
        }

        .v-lines {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: space-evenly;
            pointer-events: none;
            z-index: 2;
        }

        .vl {
            width: 1px;
            height: 100%;
            background-color: rgba(255,255,255,0.02);
            transform-origin: top;
            transform: scaleY(0);
        }

        .g-type {
            position: absolute;
            top: 30%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-family: var(--font-display);
            font-size: 18vw;
            color: transparent;
            -webkit-text-stroke: 1px rgba(255,255,255,0.05);
            opacity: 0.8;
            word-break: keep-all;
            white-space: nowrap;
            pointer-events: none;
            z-index: 0;
            line-height: 0.8;
            font-weight: 900;
        }

        /* Layout & Wrapper */
        .s-wrap {
            position: relative;
            padding: 8vw 4vw;
            min-height: 100vh;
            z-index: 5;
        }

        .g-cont {
            max-width: 1200px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }

        /* The Hero Strike */
        .hero-area {
            text-align: center;
            margin-bottom: 6vw;
            position: relative;
            z-index: 20;
        }

        .m-headline {
            font-size: clamp(3rem, 6vw, 6.5rem);
            line-height: 1.05;
            letter-spacing: -0.04em;
            margin-bottom: 2rem;
            color: #fff;
        }

        .w-wrap {
            display: inline-block;
            overflow: hidden;
            vertical-align: top;
        }

        .w-inner {
            display: inline-block;
            transform: translateY(115%);
        }

        .hl-word {
            position: relative;
            display: inline-block;
        }
        
        .hl-word::after {
            content: '';
            position: absolute;
            bottom: 5px;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #3b82f6, #ec4899);
            z-index: -1;
            opacity: 0.8;
            border-radius: 2px;
        }

        @media (max-width: 768px) {
            .landing-wrapper * {
                cursor: auto !important;
            }
            .c-dot, .c-ring {
                display: none;
            }
            .g-type {
                font-size: 11vw;
                top: 8%;
                opacity: 0.15;
            }
            .s-wrap {
                padding: 15vw 4vw;
            }
        }
    </style>

    <div class="landing-wrapper">
        <!-- SVG Noise -->
        <svg class="n-overlay" xmlns="http://www.w3.org/2000/svg">
            <filter id="n-filter">
                <feTurbulence type="fractalNoise" baseFrequency="0.7" numOctaves="3" stitchTiles="stitch"/>
            </filter>
            <rect width="100%" height="100%" filter="url(#n-filter)"/>
        </svg>

        <div class="cyber-grid" data-plax="-0.05"></div>
        <div class="g-type" data-plax="0.1">AUTORITÄT</div>

        <div class="v-lines">
            <div class="vl"></div><div class="vl"></div><div class="vl"></div><div class="vl"></div>
        </div>

        <!-- Custom Cursor -->
        <div class="c-dot"></div>
        <div class="c-ring"><span class="c-text">UPLOAD</span></div>

        <section class="s-wrap">
            <div class="g-cont">
                
                <!-- 1. Hero -->
                <div class="hero-area">
                    <h1 class="m-headline">Ihr Logo ist das Nadelöhr für <br> <span class="hl-word text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-magenta-500">B2B-Vertrauen.</span></h1>
                    <p class="text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed mb-12">
                        In den ersten Millisekunden entscheidet Ihr Gegenüber über Autorität oder Mittelmaß. Wir auditieren Ihr aktuelles Design und generieren die Architektur für maximale visuelle Dominanz.
                    </p>
                </div>

                <!-- 2. Process / Value Block -->
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-24 relative z-20">
                    <div class="bg-[#0A0A0A] border border-white/10 rounded-2xl p-8 hover:border-blue-500/30 transition-colors">
                        <div class="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center mb-6">
                            <span class="text-blue-400 font-bold text-xl">1</span>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">Status Quo Audit</h3>
                        <p class="text-gray-400">
                            Sie laden Ihr aktuelles Logo hoch oder nennen uns Ihre Website. Unser System analysiert die visuelle Schwere und strukturellen Schwachstellen.
                        </p>
                    </div>

                    <div class="bg-[#0A0A0A] border border-white/10 rounded-2xl p-8 hover:border-magenta-500/30 transition-colors">
                        <div class="w-12 h-12 rounded-full bg-magenta-500/10 flex items-center justify-center mb-6">
                            <span class="text-magenta-400 font-bold text-xl">2</span>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">KI-Benchmark</h3>
                        <p class="text-gray-400">
                            Wir gleichen Ihr Design mit hunderten erfolgreichen B2B Brands ab. Keine Canva-Templates. Purer Fokus auf "German Thoroughness".
                        </p>
                    </div>

                    <div class="bg-[#0A0A0A] border border-white/10 rounded-2xl p-8 hover:border-violet-500/30 transition-colors">
                        <div class="w-12 h-12 rounded-full bg-violet-500/10 flex items-center justify-center mb-6">
                            <span class="text-violet-400 font-bold text-xl">3</span>
                        </div>
                        <h3 class="text-2xl font-bold text-white mb-4">Authority Board</h3>
                        <p class="text-gray-400">
                            Sie erhalten ein konkretes visuelles Konzept ("Architecture Board"), wie Ihr Upgrade aussieht und psychologisch auf Entscheider wirkt.
                        </p>
                    </div>
                </div>

                <!-- 3. Validation / Pain -->
                <div class="text-center mb-16 relative z-20">
                    <h2 class="text-3xl font-bold text-white mb-4">Ein Standard-Logo kostet Sie Kunden.</h2>
                    <p class="text-gray-400 max-w-2xl mx-auto">
                        Wenn Ihr Design aussieht wie das Ihrer Mitbewerber, konkurrieren Sie automatisch über den Preis. Visuelle Autorität eliminiert diese Reibung. Starten Sie das kostenfreie Audit:
                    </p>
                </div>

                <!-- 4. The Interactive Form (Lead Capture) -->
                <div class="relative z-30 interactive-elem" style="transform: translateY(30px); opacity: 0;" id="form-container">
                    <LogoLeadForm client:load />
                </div>

            </div>
        </section>
    </div>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
            
            gsap.registerPlugin(ScrollTrigger);
            
            const isTouch = (('ontouchstart' in window) || (navigator.maxTouchPoints > 0) || (navigator.msMaxTouchPoints > 0));

            // Text Split
            const splitHeadline = new SplitType('.m-headline', { types: 'words', wordClass: 'w-inner' });
            splitHeadline.words.forEach(word => {
                const wrapper = document.createElement('span');
                wrapper.classList.add('w-wrap');
                word.parentNode.insertBefore(wrapper, word);
                wrapper.appendChild(word);
            });

            gsap.to('.w-inner', {
                y: 0,
                duration: 1.2,
                stagger: 0.1,
                ease: 'power4.out',
                delay: 0.2
            });

            gsap.to('#form-container', {
                y: 0,
                opacity: 1,
                duration: 1.2,
                ease: 'power3.out',
                delay: 0.8
            });

            // Scroll Animations
            gsap.to('.vl', {
                scaleY: 1,
                duration: 1.5,
                ease: 'expo.inOut',
                stagger: 0.1,
                scrollTrigger: {
                    trigger: '.s-wrap',
                    start: 'top 80%',
                }
            });

            // Parallax
            document.querySelectorAll('[data-plax]').forEach(el => {
                const speed = parseFloat(el.getAttribute('data-plax'));
                gsap.to(el, {
                    yPercent: speed * 100,
                    ease: 'none',
                    scrollTrigger: {
                        trigger: '.s-wrap',
                        start: 'top bottom',
                        end: 'bottom top',
                        scrub: true
                    }
                });
            });

            // Interactions
            if (!isTouch) {
                const cDot = document.querySelector('.c-dot');
                const cRing = document.querySelector('.c-ring');
                
                const xToDot = gsap.quickTo(cDot, "x", {duration: 0.15, ease: "power3"});
                const yToDot = gsap.quickTo(cDot, "y", {duration: 0.15, ease: "power3"});
                const xToRing = gsap.quickTo(cRing, "x", {duration: 0.3, ease: "power3"});
                const yToRing = gsap.quickTo(cRing, "y", {duration: 0.3, ease: "power3"});

                window.addEventListener('mousemove', e => {
                    xToDot(e.clientX);
                    yToDot(e.clientY);
                    xToRing(e.clientX);
                    yToRing(e.clientY);
                });

                document.querySelectorAll('.interactive-elem').forEach(el => {
                    el.addEventListener('mouseenter', () => document.body.classList.add('c-interactive'));
                    el.addEventListener('mouseleave', () => document.body.classList.remove('c-interactive'));
                });
            }
        });
    </script>
</BaseLayout>
