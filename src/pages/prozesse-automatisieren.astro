---
import BaseLayout from "../layouts/BaseLayout.astro";
import { blogPosts } from "../data/blogData";

const relevantPosts = blogPosts.filter(p => p.id !== "welcome-to-our-blog");

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Prozesse automatisieren mit KI – Leitfaden für den Mittelstand",
  "description": "Welche Geschäftsprozesse sich für KI-Automatisierung eignen, wo der ROI am höchsten ist und wie der Einstieg im Mittelstand aussieht.",
  "url": "https://ki-automatisieren.de/prozesse-automatisieren",
  "publisher": {
    "@type": "Organization",
    "name": "KI Automatisieren",
    "url": "https://ki-automatisieren.de"
  }
});
---

<BaseLayout
  title="Prozesse automatisieren mit KI – Leitfaden für den Mittelstand | ki-automatisieren.de"
  description="Welche Geschäftsprozesse sich für KI-Automatisierung eignen, wo der ROI am höchsten ist und wie der Einstieg konkret aussieht."
>
  <script type="application/ld+json" set:html={schema} />

  <section class="py-24 px-4 max-w-4xl mx-auto">

    <!-- Hero -->
    <div class="mb-14">
      <p class="text-sm font-medium text-primary uppercase tracking-widest mb-3">Prozesse automatisieren</p>
      <h1 class="text-4xl md:text-5xl font-bold text-foreground mb-5 leading-tight">
        Welche Prozesse lohnt es sich zu automatisieren?
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl leading-relaxed">
        Nicht jeder Prozess ist ein guter Kandidat für KI-Automatisierung. Die richtigen zu finden — und in der richtigen Reihenfolge anzugehen — entscheidet über Erfolg oder Zeitverschwendung.
      </p>
    </div>

    <!-- Was lohnt sich -->
    <div class="mb-14">
      <h2 class="text-2xl font-semibold text-foreground mb-6">Das richtige Auswahlkriterium</h2>
      <p class="text-muted-foreground leading-relaxed mb-4">
        Ein Prozess eignet sich für Automatisierung wenn er drei Eigenschaften hat: <strong class="text-foreground">repetitiv</strong> (wird regelmäßig wiederholt), <strong class="text-foreground">regelbasiert</strong> (folgt klaren Entscheidungsregeln) und <strong class="text-foreground">datengetrieben</strong> (arbeitet mit strukturierten Informationen).
      </p>
      <p class="text-muted-foreground leading-relaxed mb-8">
        Prozesse, die Urteilsvermögen, Kreativität oder menschliche Empathie erfordern, sind schlechte Kandidaten für vollständige Automatisierung — aber gute für KI-Unterstützung, die den Menschen schneller macht.
      </p>

      <!-- Prozess-Matrix -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
        {[
          { title: "Rechnungsverarbeitung", roi: "Sehr hoch", effort: "Mittel", desc: "OCR + ERP-Integration eliminiert manuelle Dateneingabe vollständig.", link: "/blog/rechnungsverarbeitung-ki-automatisierung-mittelstand" },
          { title: "Kundenservice (Tier 1)", roi: "Hoch", effort: "Mittel", desc: "65–80% der Anfragen lassen sich ohne menschlichen Eingriff lösen.", link: "/blog/kundenservice-chatbot-ki-mittelstand-automatisierung" },
          { title: "Lead-Qualifizierung", roi: "Hoch", effort: "Mittel", desc: "Automatisches Scoring und Follow-up verdoppelt die Vertriebseffizienz.", link: "/blog/vertrieb-lead-qualifizierung-ki-mittelstand" },
          { title: "Dokumenten-Extraktion", roi: "Hoch", effort: "Niedrig", desc: "Lieferscheine, Verträge, Formulare — KI liest und strukturiert automatisch.", link: "/blog/digitale-prozessoptimierung-unternehmen/" },
          { title: "E-Mail-Klassifizierung", roi: "Mittel", effort: "Niedrig", desc: "Eingehende Mails werden automatisch kategorisiert und weitergeleitet.", link: "/blog/e-mail-automatisierung-vertrieb-marketing/" },
          { title: "Berichts-Erstellung", roi: "Mittel", effort: "Niedrig", desc: "Wöchentliche Reports aus ERP/CRM-Daten ohne manuelle Aufbereitung.", link: "/blog/prozessoptimierung-ki-mittelstand-leitfaden/" },
        ].map(p => (
          <div class="border border-border rounded-xl p-5 hover:border-primary/40 transition-colors">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold text-foreground text-sm">{p.title}</h3>
              <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${p.roi === "Sehr hoch" ? "bg-primary/20 text-primary" : p.roi === "Hoch" ? "bg-green-500/10 text-green-400" : "bg-muted text-muted-foreground"}`}>
                ROI: {p.roi}
              </span>
            </div>
            <p class="text-xs text-muted-foreground leading-relaxed mb-3">{p.desc}</p>
            {p.link && (
              <a href={p.link} class="text-xs text-primary hover:underline font-medium">
                Ausführlicher Artikel →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Reihenfolge -->
    <div class="mb-14">
      <h2 class="text-2xl font-semibold text-foreground mb-6">Die richtige Reihenfolge</h2>
      <p class="text-muted-foreground leading-relaxed mb-6">
        Mittelständler, die mit KI-Automatisierung beginnen, starten am besten mit Prozessen, die drei Eigenschaften haben: hohen Zeitaufwand, klare Datenstruktur und messbaren Output. Das schafft schnelle Erfolge, baut internes Vertrauen auf und finanziert die nächste Stufe.
      </p>
      <div class="space-y-3">
        {[
          { step: "1", title: "Quick Wins identifizieren", desc: "Prozesse mit hohem manuellem Aufwand und klar definierten Regeln. Typisch: Rechnungsverarbeitung, E-Mail-Weiterleitung, Report-Generierung." },
          { step: "2", title: "Pilot mit echten Daten", desc: "Kein Big Bang. Ein Prozess, in einer Abteilung, parallel zur manuellen Bearbeitung. Qualität messen, anpassen, dann ausrollen." },
          { step: "3", title: "Integration in bestehende Systeme", desc: "Die Automatisierung muss in Ihr ERP, CRM und Helpdesk integriert sein — kein weiteres Tool das manuell gepflegt werden muss." },
          { step: "4", title: "Skalierung auf weitere Prozesse", desc: "Erst wenn Pilot stabil läuft, werden weitere Prozesse angebunden. Kein paralleler Aufbau von drei Automatisierungen gleichzeitig." },
        ].map(s => (
          <div class="flex gap-4 p-4 border border-border rounded-xl">
            <span class="text-primary font-bold text-lg w-6 shrink-0">{s.step}</span>
            <div>
              <p class="font-medium text-foreground text-sm mb-1">{s.title}</p>
              <p class="text-xs text-muted-foreground leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Blog-Artikel -->
    <div class="mb-14">
      <h2 class="text-2xl font-semibold text-foreground mb-6">Detaillierte Anleitungen nach Prozess</h2>
      <div class="space-y-4">
        {relevantPosts.map(post => (
          <a href={`/blog/${post.id}`} class="flex items-start gap-4 p-5 border border-border rounded-xl hover:border-primary/40 transition-colors group">
            <div class="flex-1">
              <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-0.5 rounded-full mb-2 inline-block">
                {post.category}
              </span>
              <h3 class="font-semibold text-foreground text-sm mb-1 group-hover:text-primary transition-colors">
                {post.title}
              </h3>
              <p class="text-xs text-muted-foreground leading-relaxed">{post.excerpt}</p>
            </div>
            <span class="text-primary text-sm shrink-0 mt-1">→</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Cross-Link Hub -->
    <div class="mb-14">
      <a href="/prozessoptimierung/" class="flex items-center justify-between p-5 border border-border rounded-xl hover:border-primary/40 transition-colors group">
        <div>
          <p class="font-semibold text-foreground text-sm group-hover:text-primary transition-colors">Prozessoptimierung mit KI — Methodik & ROI</p>
          <p class="text-xs text-muted-foreground mt-1">Priorisierungs-Matrix, Fehler-Analyse und realistischer ROI in 12 Monaten.</p>
        </div>
        <span class="text-primary shrink-0 ml-4">→</span>
      </a>
    </div>

    <!-- CTA -->
    <div class="bg-primary/5 border border-primary/20 rounded-xl p-8">
      <h3 class="text-xl font-semibold text-foreground mb-2">
        Welche Prozesse lohnen sich in Ihrem Unternehmen?
      </h3>
      <p class="text-muted-foreground text-sm mb-6 leading-relaxed">
        Wir machen eine kostenlose Bestandsaufnahme: Welche Prozesse haben den höchsten Automatisierungs-ROI, was kostet die Implementierung, wann amortisiert sich das Investment.
      </p>
      <a
        href="/termin/"
        class="inline-flex items-center gap-2 bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium text-sm hover:bg-primary/90 transition-colors"
      >
        Kostenlose Prozessanalyse vereinbaren →
      </a>
    </div>

  </section>
</BaseLayout>
