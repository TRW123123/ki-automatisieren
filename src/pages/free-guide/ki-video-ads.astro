---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PdfLeadFunnel from "@/components/react/PdfLeadFunnel.tsx";

const seoTitle = "Kostenloser Guide: KI Cinematic Video Ads erstellen";
const seoDescription = "Lerne, wie du mit simplen Handy-Shots und KI (Gemini, Nano Banana Pro) High-End Werbevideos generierst. Lade jetzt das kostenlose PDF herunter.";
---

<BaseLayout title={seoTitle} description={seoDescription}>
    <!-- GSAP for Animations -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>

    <style is:inline>
        :root {
            --bg-base: hsl(203, 23%, 8%);
            --surface: hsl(220, 13%, 9%);
            --text-main: hsl(210, 10%, 90%);
            --text-muted: hsl(215, 16%, 58%);
            --font-display: 'Space Grotesk', system-ui, sans-serif;
            --font-ui: 'Space Grotesk', system-ui, sans-serif;
        }

        .landing-wrapper {
            background-color: var(--bg-base);
            color: var(--text-main);
            font-family: var(--font-ui);
            min-height: 100vh;
            position: relative;
            overflow: hidden;
        }

        .landing-wrapper h1, .landing-wrapper h2, .landing-wrapper .display-font {
            font-family: var(--font-display);
            font-weight: 700;
        }

        /* SVG Noise Overlay */
        .n-overlay {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 10;
            opacity: 0.15;
            mix-blend-mode: overlay;
        }

        /* Cyberpunk Grid Background */
        .cyber-grid {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
            background-size: 50px 50px;
            mask-image: radial-gradient(ellipse at center, black 0%, transparent 80%);
            -webkit-mask-image: radial-gradient(ellipse at center, black 0%, transparent 80%);
            pointer-events: none;
            z-index: 1;
        }

        /* Ambient Glows */
        .ambient-glow {
            position: absolute;
            width: 800px;
            height: 800px;
            background: radial-gradient(circle, rgba(163, 230, 53, 0.08) 0%, transparent 70%);
            top: -200px;
            left: 50%;
            transform: translateX(-50%);
            pointer-events: none;
            z-index: 2;
        }

        .content-area {
            position: relative;
            z-index: 20;
            max-width: 1200px;
            margin: 0 auto;
            padding: 10vh 4vw;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            min-height: 100vh;
        }

        .hl-word {
            position: relative;
            display: inline-block;
        }
        
        .hl-word::after {
            content: '';
            position: absolute;
            bottom: 4px;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, #A3E635, #22c55e);
            z-index: -1;
            opacity: 0.8;
            border-radius: 2px;
        }

        .hero-title {
            font-size: clamp(2.5rem, 5vw, 5rem);
            line-height: 1.1;
            letter-spacing: -0.03em;
            color: #fff;
            text-align: center;
            margin-bottom: 1.5rem;
            max-width: 900px;
        }

        .hero-p {
            font-size: clamp(1.1rem, 1.5vw, 1.3rem);
            color: var(--text-muted);
            text-align: center;
            max-width: 700px;
            margin-bottom: 4rem;
            line-height: 1.6;
        }
    </style>

    <div class="landing-wrapper">
        <svg class="n-overlay" xmlns="http://www.w3.org/2000/svg">
            <filter id="n-filter">
                <feTurbulence type="fractalNoise" baseFrequency="0.6" numOctaves="3" stitchTiles="stitch"/>
            </filter>
            <rect width="100%" height="100%" filter="url(#n-filter)"/>
        </svg>

        <div class="cyber-grid"></div>
        <div class="ambient-glow"></div>

        <main class="content-area max-w-6xl mx-auto w-full flex flex-col lg:flex-row items-center justify-center gap-12 lg:gap-16 pt-8 pb-24">
            
            <!-- LEFT: Hero Text & The REQUIRED Funnel (Always Above Fold) -->
            <div class="flex-1 w-full text-center lg:text-left opacity-0 translate-y-8 hero-left flex flex-col justify-center order-1">
                <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white mb-4 leading-[1.1] tracking-tight display-font">
                    KI-Werbevideos in <span class="text-[#A3E635]">15 Min.</span>
                </h1>
                <p class="text-lg sm:text-xl text-gray-400 mb-8 max-w-lg mx-auto lg:mx-0">
                    Die exakte Schritt-für-Schritt PDF-Anleitung. 100% kostenlos.
                </p>
                
                <!-- The Funnel is now IMMEDIATELY under the text so it is always visible -->
                <div class="w-full max-w-xl mx-auto lg:mx-0">
                    <PdfLeadFunnel client:load />
                    <div className="mt-4 text-center">
                        <p class="text-xs text-gray-600 flex items-center justify-center lg:justify-start gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                            100% Sicher. Kein Spam.
                        </p>
                    </div>
                </div>
            </div>

            <!-- RIGHT/BOTTOM: The Trust Mockup (Secondary Element) -->
            <div class="flex-1 w-full flex justify-center opacity-0 translate-y-8 funnel-right mt-4 lg:mt-0 order-2">
                <div class="relative inline-block max-w-xs sm:max-w-sm w-full perspective-[1000px]">
                    <div class="absolute inset-0 bg-lime-500/20 blur-[50px] rounded-full hidden sm:block"></div>
                    <img src="/assets/pdf_mockup.png" alt="Vorschau der PDF Anleitung" class="relative z-10 w-full rounded-2xl border border-white/10 shadow-2xl transform hover:scale-105 transition-transform duration-500" />
                    
                    <div class="absolute -bottom-4 -right-4 sm:-bottom-6 sm:-right-6 bg-black/90 backdrop-blur-md border border-[#A3E635]/30 text-white text-xs font-bold px-3 py-1.5 sm:px-4 sm:py-2 rounded-lg flex items-center gap-2 z-20 shadow-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#A3E635" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                        SSL-Geprüfte Datei
                    </div>
                </div>
            </div>
            
        </main>
    </div>

    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof gsap === 'undefined') return;
            
            const tl = gsap.timeline();
            
            tl.to('.hero-left', {
                y: 0,
                opacity: 1,
                duration: 1.0,
                ease: 'power3.out'
            })
            .to('.funnel-right', {
                y: 0,
                opacity: 1,
                duration: 1.0,
                ease: 'power3.out'
            }, "-=0.6");
        });
    </script>
</BaseLayout>
