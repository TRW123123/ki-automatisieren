---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Agitate from "@/components/Agitate.tsx";
import GoToMarketTimeline from "@/components/GoToMarketTimeline.tsx";
import SolutionSection from "@/components/SolutionSection.tsx";
import Cases from "@/components/Cases.tsx";
import PseoHub from "@/components/PseoHub.astro";
import IndustrySection from "@/components/IndustrySection.astro";
import RoiCalculator from "@/components/RoiCalculator.astro";
import GeoBlock from "@/components/seo/GeoBlock.astro";
import { buildGeoGraph } from "@/lib/geoSchema";
import { hubGeo } from "../data/geoEnhancements";

// Pure Strict Alignment Index Page
// Structure: GeoBlock -> Hero -> Agitate -> IndustrySection -> GoToMarketTimeline -> Solution -> Cases

const pageUrl = "https://ki-automatisieren.de/";
const today = new Date().toISOString().split("T")[0];

// Konsolidierter GEO-Graph: Organization + Person + Article (homepage als Service-Hub)
const geoGraph = buildGeoGraph({
  type: "Article",
  url: pageUrl,
  headline: "KI Automatisierung für Vertrieb, Kundenservice und Marketing",
  description:
    "KI Automatisierung im DACH-Mittelstand: vollständige Pipelines für Lead-Generierung, Kundenservice und Dokumentenverarbeitung. Setup in 2–4 Wochen, ohne IT-Abteilung.",
  datePublished: "2024-01-15",
  dateModified: today,
  geo: hubGeo,
});
---

<BaseLayout
  title="KI Automatisierung für Mittelstand & B2B | ki-automatisieren.de"
  description="KI Automatisierung im Mittelstand: vollständige Lead-, Vertriebs- und Marketing-Pipelines mit n8n, GPT-4o und Claude. 60–80 % weniger manuelle Arbeit, Setup in 2–4 Wochen — Beratung von ki-automatisieren.de."
>
  <!-- GEO-Graph JSON-LD: Organization + Person + Article -->
  <script type="application/ld+json" set:html={geoGraph} />

  <!-- GEO-Block: TLDR + Definition + Stats — LLM-Citation-Magnet ganz oben -->
  <GeoBlock geo={hubGeo} />

  <Hero />
  <Agitate client:load />
  <RoiCalculator />
  <IndustrySection />
  <SolutionSection client:load />
  <GoToMarketTimeline client:load />
  <PseoHub />
  <Cases client:load />
</BaseLayout>
