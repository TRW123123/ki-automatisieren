---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Termin buchen - KI Automatisieren";
const description =
  "Buchen Sie Ihre kostenlose Potenzialanalyse für KI-Automatisierung und Leadgenerierung.";
---

<BaseLayout title={title} description={description} type="website">
  <section class="py-24 md:py-32 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(163,230,53,0.05),transparent_50%)] pointer-events-none"></div>

    <div class="container mx-auto px-4 max-w-4xl relative z-10">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Kostenlose <span class="text-lime-400">Potenzialanalyse</span>
        </h1>
        <p class="text-xl text-muted-foreground leading-relaxed max-w-2xl mx-auto">
          Lassen Sie uns herausfinden, wie wir Ihre Prozesse durch KI im B2B-Umfeld automatisieren und Ihren Vertrieb skalieren können.
        </p>
      </div>

      <div class="rounded-2xl bg-card border border-white/10 p-2 md:p-4 shadow-2xl overflow-hidden min-h-[700px]">
        <!-- Calendly inline widget begin -->
        <div class="calendly-inline-widget" data-url="https://calendly.com/st-automatisierung-info/30min?hide_event_type_details=1&hide_gdpr_banner=1&background_color=0a0a0a&text_color=ffffff&primary_color=a3e635" style="min-width:320px;height:700px;"></div>
        <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
        <!-- Calendly inline widget end -->
      </div>
    </div>
  </section>
</BaseLayout>
